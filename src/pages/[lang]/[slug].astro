---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async () => {
  const perfumes = await getCollection("perfumes");

  return perfumes.map((perfume) => {
    const [lang, filename] = perfume.id.split("/");

    const slug = filename.replace(`-${lang}.md`, "");

    return {
      params: {
        lang,
        slug,
      },
      props: {
        perfume,
      },
    };
  });
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
import Layout from "@Layout/Layout.astro";
const { perfume } = Astro.props;
const { Content } = await perfume.render();
---

<Layout locale={lang}>
  <article
    class="w-full min-h-screen flex flex-col items-center justify-center gap-6 px-6 md:flex-row md:items-center md:justify-between md:px-20"
  >
    <div class="w-full flex justify-center md:w-1/2 relative">
      <div class="absolute w-64 h-64 bg-yellow-400/20 blur-3xl rounded-full">
      </div>

      <img
        src={perfume.data.url}
        alt="Perfume image"
        class="relative w-60 md:w-96 h-auto object-cover transition-transform duration-500 hover:scale-105"
      />
    </div>

    <section
      class="w-full md:w-1/2 flex flex-col gap-4 text-center md:text-left"
    >
      <span class="text-xs uppercase tracking-widest text-yellow-400">
        Perfume Exclusivo
      </span>

      <h1
        class="text-3xl md:text-5xl font-bold text-yellow-400 font-raleway leading-tight"
      >
        {perfume.data.title}
      </h1>

      <span class="text-xl md:text-2xl text-white font-semibold">
        {perfume.data.price}
      </span>

      <div class="w-16 h-0.5 bg-yellow-400 mx-auto md:mx-0"></div>

      <article
        class="prose prose-invert max-w-none text-gray-300 text-sm md:text-base"
      >
        <Content />
      </article>

      <section
        class="flex flex-row gap-4 mt-4 items-center md:items-start justify-center md:justify-start"
      >
        <a
          href=`https://wa.me/573001666077?text=Hola%20me%20ha%20gustado%20el%20perfume%20${perfume.data.title}%20y%20quiero%20saber%20más%20información%20sobre%20él`
          class="px-6 py-3 bg-yellow-400 text-black font-medium rounded-md hover:bg-yellow-300 transition cursor-pointer"
        >
          Comprar
        </a>

        <a
          href="#"
          class="px-6 py-3 border border-yellow-400 text-yellow-400 rounded-md"
        >
          Proximamente..
        </a>
      </section>
    </section>
  </article>
</Layout>
