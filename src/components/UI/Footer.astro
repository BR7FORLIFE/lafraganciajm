---
import { type TranslationProps } from "@Lib/types/translationTypeProps";
const { t } = Astro.props as TranslationProps;

interface Contact {
  name: string;
  links: {
    url: string;
    image: string;
    alt: string;
  };
}

const contacts: Contact[] = [
  {
    name: "+57 3001666077",
    links: {
      url: "https://wa.me/573233375315?text=Hola%20quiero%20información%20sobre%20sus%20servicios",
      image: "/resources/hero/contacts/cellphone.svg",
      alt: "cellphone icon",
    },
  },
  {
    name: "jorgeospinom202@gmail.com",
    links: {
      url: "mailto:correo@ejemplo.com?subject=Consulta%20perfumes&body=Hola%20quiero%20información",
      image: "/resources/hero/contacts/email.svg",
      alt: "email icon",
    },
  },
  {
    name: "Cartagena De indias, Colombia",
    links: {
      url: "https://maps.google.com/?q=Cartagena,Bolivar",
      image: "/resources/hero/contacts/location.svg",
      alt: "location icon",
    },
  },
];

const subtitle = t("footer").subtitle;
const contact = t("footer").contact;
const newletter = t("footer").newletter;
const copiright = t("footer").copiright;
---

<section
  class="w-full min-h-screen flex flex-col justify-center px-4 md:justify-around"
>
  <!--mobile first -->
  <article
    class="w-full flex flex-col gap-6 md:flex-row md:justify-evenly md:mt-12"
  >
    <!--mensaje de motivacion y titulo -->
    <div class="inline-flex flex-col gap-4 font-raleway md:w-1/3">
      <span class="text-lg md:text-3xl font-bold text-primary"
        >LaFraganciaJM</span
      >
      <p class="text-sm md:text-lg text-white/70">
        {subtitle}
      </p>
    </div>

    <!--zona de contactos -->
    <div class="flex flex-col gap-2">
      <span class="font-raleway font-semibold text-neutral-300 text-lg"
        >{contact}</span
      >
      {
        contacts.map(({ name, links }) => {
          return (
            <div class="flex justify-start gap-2">
              <img
                src={links.image}
                alt={links.alt}
                class="w-5 h-auto object-contain"
              />
              <a
                href={links.url}
                target="_blank"
                class="text-neutral-400 font-raleway"
              >
                {name}
              </a>
            </div>
          );
        })
      }
    </div>

    <!--newletter -->
    <div class="flex flex-col gap-4 md:w-1/3">
      <span class="font-bold text-sm font-raleway text-neutral-300"
        >{newletter}</span
      >
      <div class="h-10 flex justify-center items-center px-4 gap-2">
        <input
          type="text"
          placeholder="Tu Correo"
          class="w-full h-full border border-yellow-300/60 rounded-lg text-white text-sm pl-4"
        />
        <button
          class="bg-primary opacity-90 w-16 h-full rounded-lg flex justify-center items-center"
        >
          <img
            src="/resources/footer/send.svg"
            alt=""
            class="w-6 h-full object-contain"
          />
        </button>
      </div>
    </div>
  </article>
  <!--marcas de agua año de creacion y desarrollador -->
  <div
    class="mt-8 inline-flex flex-col justify-center items-center font-sans text-sm text-white/60"
  >
    <span>© {new Date().getFullYear()} LaFraganciaJM</span>
    <p>{copiright}</p>
    <span>BR7FORLIFE</span>
  </div>
</section>
