{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@Assets/*": ["assets/"],
      "@Components/*": ["components/*"],
      "@Content/*": ["content/*"],
      "@i18n/*": ["i18n/*"],
      "@Layout/*": ["layouts/*"],
      "@Lib/*": ["lib/*"],
      "@Pages/*": ["pages/*"],
      "@Styles/*": ["styles/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true
  }
}
